# Copy this file to .env.local and fill in real values.

# --- Clerk (Auth / Organizations) ---
# Publishable key is safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret key MUST stay server-side. Never commit the real value.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override Clerk's default sign-in / sign-up routes.
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Database (Railway Postgres via Drizzle) ---
DATABASE_URL=postgresql://user:password@host:5432/database
